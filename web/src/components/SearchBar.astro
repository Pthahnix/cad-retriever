---
---
<div class="topbar">
  <h1>CAD Retriever</h1>
  <div class="searchbox">
    <input id="text-input" type="text" value="flat disc with mounting holes" placeholder="描述一个 CAD 零件…" />

    <button class="upload-btn" id="sketch-btn" type="button" title="上传草图" aria-label="上传草图">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
    </button>
    <button class="upload-btn" id="image-btn" type="button" title="上传图片" aria-label="上传图片">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="1.5"/><path d="m21 15-4.5-4.5L7 20"/></svg>
    </button>

    <div class="divider"></div>
    <span class="mode-tag" id="mode-tag">Text</span>
    <button class="go-btn" id="search-btn" type="button">Go</button>

    <input type="file" id="sketch-file" accept="image/*" hidden />
    <input type="file" id="image-file" accept="image/*" hidden />
  </div>
</div>

<div class="attach" id="attach">
  <img id="attach-thumb" alt="" />
  <span id="attach-label"></span>
  <button class="x" id="attach-x" type="button" title="移除">✕</button>
</div>

<p id="status" class="status" hidden>Searching…</p>
<script src="../scripts/search.ts"></script>
